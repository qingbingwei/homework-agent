{
  "name": "homework-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript agent powered by LangChain + LangGraph",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:live": "AGENT_LIVE_TEST=1 vitest run tests/live/agent.live.test.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.1",
    "@langchain/core": "^0.3.34",
    "@langchain/langgraph": "^0.2.40",
    "@langchain/openai": "^0.3.17",
    "dotenv": "^16.4.5",
    "execa": "^9.5.1",
    "fastify": "^5.1.0",
    "jszip": "^3.10.1",
    "langchain": "^0.3.10",
    "langsmith": "^0.2.10",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
