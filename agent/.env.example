# plan-write：任务分析 + 最终文档编写（DeepSeek）
PLAN_LLM_BASE_URL=https://api.deepseek.com/v1
PLAN_LLM_API_KEY=sk-replace-me
PLAN_LLM_MODEL=deepseek-v4-pro
PLAN_LLM_REASONING_EFFORT=high
PLAN_LLM_THINKING_TYPE=enabled

# coding-agent：基于 plan-write 的任务拆解执行代码编写（GPT）
CODING_LLM_MODEL_PROVIDER=OpenAI
CODING_LLM_BASE_URL=https://api.asxs.top/v1
CODING_LLM_API_KEY=sk-replace-me
CODING_LLM_MODEL=gpt-5.5
CODING_LLM_REVIEW_MODEL=gpt-5.5
CODING_LLM_REASONING_EFFORT=xhigh
CODING_LLM_THINKING_TYPE=enabled
CODING_LLM_DISABLE_RESPONSE_STORAGE=true
CODING_LLM_NETWORK_ACCESS=enabled
CODING_LLM_WINDOWS_WSL_SETUP_ACKNOWLEDGED=true
CODING_LLM_CONTEXT_WINDOW=400000
CODING_LLM_AUTO_COMPACT_TOKEN_LIMIT=360000
CODING_LLM_WIRE_API=responses
CODING_LLM_REQUIRES_OPENAI_AUTH=true

# coding-agent 可选 DeepSeek profile：独立配置，不复用 PLAN_LLM_*
CODING_DEEPSEEK_LLM_BASE_URL=https://api.deepseek.com/v1
CODING_DEEPSEEK_LLM_API_KEY=sk-replace-me
CODING_DEEPSEEK_LLM_MODEL=deepseek-v4-pro
CODING_DEEPSEEK_LLM_REASONING_EFFORT=max
CODING_DEEPSEEK_LLM_THINKING_TYPE=enabled

AGENT_HOST=127.0.0.1
AGENT_PORT=19000

# LangSmith 追踪：填入 API Key 并将 TRACING 置为 true 即生效
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=homework
